ELASTICSEARCH_URL=https://user_name:password@test.bonsaisearch.net
DEFAULT_INDEX=restaurants
PORT=8080

# Comma-separated list of ES indices allowed for querying. Defaults to DEFAULT_INDEX.
ALLOWED_INDICES=restaurants

# Comma-separated list of allowed CORS origins. Leave unset to allow all origins (dev only).
# CORS_ORIGINS=https://your-frontend.com,https://staging.your-frontend.com
